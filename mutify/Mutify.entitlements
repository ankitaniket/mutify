<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Required so dyld can load Sparkle.framework, which is signed by the
         Sparkle Project. Without this, Library Validation rejects the framework
         because its Team ID does not match Mutify's (we're ad-hoc signed). -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
